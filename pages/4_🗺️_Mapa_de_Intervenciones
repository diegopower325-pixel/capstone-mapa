import streamlit as st
import pandas as pd
import folium
from streamlit_folium import st_folium

# Configuración de la página
st.set_page_config(page_title="Mapa de Intervenciones", layout="wide")
st.title("📍 Distribución Geográfica de Intervenciones de Limpieza")
st.write("Visualización interactiva de los sectores intervenidos en Temuco.")

# Nombre del archivo real que se ve en tu captura de pantalla
ARCHIVO_DATOS = "datos_vactor.csv"

try:
    df = pd.read_csv(ARCHIVO_DATOS)
    
    # Comprobar que las columnas de coordenadas existan exactamente como en tu Excel
    if 'Coordenada X' not in df.columns or 'Coordenada Y' not in df.columns:
        st.error("Error: No se encontraron las columnas 'Coordenada X' o 'Coordenada Y' en el archivo CSV.")
        st.stop()

    # Selector interactivo para el menú de Streamlit
    criterio = st.selectbox(
        "Selecciona el criterio para clasificar los puntos en el mapa:",
        ["Unidades Vecinales", "Microsector", "Macrosector"]
    )

    # Mapeamos la selección. Si tus columnas en el CSV se llaman diferente, cámbialas a la derecha.
    columna_mapa = {
        "Unidades Vecinales": "unidad_vecinal", 
        "Microsector": "microsector",
        "Macrosector": "macrosector"
    }[criterio]
    
    # Si las columnas de sectores aún no están creadas en tu CSV, creamos una temporal para que no falle
    if columna_mapa not in df.columns:
        st.warning(f"Nota: La columna '{columna_mapa}' no está en el CSV actual. Mostrando puntos con un color base.")
        df[columna_mapa] = "Intervención Registrada"

    # Paleta de colores para los círculos
    colores_disponibles = [
        "red", "blue", "green", "purple", "orange", "darkred", "cadetblue", 
        "darkpurple", "pink", "darkblue", "darkgreen"
    ]

    categorias_unicas = df[columna_mapa].dropna().unique()
    diccionario_colores = {}
    for i, cat in enumerate(categorias_unicas):
        diccionario_colores[cat] = colores_disponibles[i % len(colores_disponibles)]

    # Crear el mapa base centrado en Temuco (Servidor público de ArcGIS)
    mapa = folium.Map(
        location=[-38.748, -72.612], 
        zoom_start=12, 
        tiles="https://server.arcgisonline.com/ArcGIS/rest/services/World_Topo_Map/MapServer/tile/{z}/{y}/{x}",
        attr="Esri / ArcGIS Online"
    )

    # Dibujar los marcadores circulares con precisión decimal completa
    for index, fila in df.iterrows():
        lat = fila['Coordenada Y']
        lon = fila['Coordenada X']
        
        if pd.isna(lat) or pd.isna(lon):
            continue
            
        categoria_actual = fila[columna_mapa]
        color_punto = diccionario_colores.get(categoria_actual, "blue")
            
        info_popup = f"""
        <b>Coordenada X:</b> {lon}<br>
        <b>Coordenada Y:</b> {lat}<br>
        <b>{criterio}:</b> {categoria_actual}
        """
        
        folium.CircleMarker(
            location=[lat, lon],
            radius=6,
            popup=folium.Popup(info_popup, max_width=250),
            color=color_punto,
            fill=True,
            fill_color=color_punto,
            fill_opacity=0.7
        ).add_to(mapa)

    # Desplegar el mapa en Streamlit
    st_folium(mapa, width="100%", height=600)

    # Mostrar la leyenda ordenadamente
    st.markdown("### 📊 Leyenda de Sectores")
    cols = st.columns(3)
    for i, (cat, col) in enumerate(diccionario_colores.items()):
        with cols[i % 3]:
            st.markdown(f"🟢 **{cat}**")

except FileNotFoundError:
    st.error(f"No se pudo cargar el archivo '{ARCHIVO_DATOS}'. Verifica que esté en la raíz del repositorio.")
